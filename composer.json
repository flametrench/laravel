{
    "name": "flametrench/laravel",
    "description": "Laravel adapter for Flametrench: ServiceProvider + facades + middleware bridging the flametrench/{ids,identity,tenancy,authz} PHP SDKs into Laravel applications.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["flametrench", "laravel", "identity", "tenancy", "authorization", "multi-tenancy"],
    "homepage": "https://flametrench.dev",
    "authors": [
        {
            "name": "NDC Digital, LLC",
            "homepage": "https://flametrench.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "flametrench/ids": "^0.2.0-rc",
        "flametrench/identity": "^0.2.0-rc",
        "flametrench/tenancy": "^0.2.0-rc",
        "flametrench/authz": "^0.2.0-rc"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Flametrench\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "php -d xdebug.mode=coverage vendor/bin/pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Flametrench\\Laravel\\FlametrenchServiceProvider"
            ],
            "aliases": {
                "Flametrench": "Flametrench\\Laravel\\Facades\\Flametrench"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "repositories": [
        { "type": "path", "url": "../ids-php",      "options": { "symlink": false, "versions": { "flametrench/ids":      "0.2.0-rc.99" } } },
        { "type": "path", "url": "../identity-php", "options": { "symlink": false, "versions": { "flametrench/identity": "0.2.0-rc.99" } } },
        { "type": "path", "url": "../tenancy-php",  "options": { "symlink": false, "versions": { "flametrench/tenancy":  "0.2.0-rc.99" } } },
        { "type": "path", "url": "../authz-php",    "options": { "symlink": false, "versions": { "flametrench/authz":    "0.2.0-rc.99" } } }
    ]
}
